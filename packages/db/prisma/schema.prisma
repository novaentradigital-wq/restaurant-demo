// QR Menu & Garson Sipariş SaaS — PostgreSQL şeması
// Multi-tenancy: tek DB + RLS (her tabloda tenant_id)
// Migration tarafında RLS politikaları, partition'lar ve trigger'lar
// `migrations/.../migration.sql` dosyasında ham SQL ile uygulanır.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, pg_trgm, citext, btree_gist]
}

// ─────────────────────────── ENUMS ───────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  WAITER
  KITCHEN
  BAR
  CASHIER
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum TableStatus {
  EMPTY
  OCCUPIED
  CALL_WAITER
  BILL_REQUESTED
  READY_TO_SERVE
  RESERVED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum StationType {
  KITCHEN
  BAR
}

enum CallType {
  WAITER
  BILL
  WATER
  OTHER
}

enum CallStatus {
  PENDING
  ACKNOWLEDGED
  RESOLVED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  VOID
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum LanguageCode {
  TR
  EN
}

enum DiscountTarget {
  ALL
  CATEGORY
  PRODUCT
}

// ─────────────────────────── SAAS ───────────────────────────

model Tenant {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique @db.Citext
  ownerEmail  String    @db.Citext
  phone       String?
  isActive    Boolean   @default(true)
  suspendedAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  restaurants   Restaurant[]
  users         User[]
  subscriptions Subscription[]
  invoices      Invoice[]

  @@map("tenants")
}

model SubscriptionPlanRef {
  code         SubscriptionPlan @id
  name         String
  maxBranches  Int
  maxTables    Int
  maxProducts  Int
  maxUsers     Int
  monthlyPrice Decimal          @db.Decimal(10, 2)
  yearlyPrice  Decimal          @db.Decimal(10, 2)
  features     Json             @default("{}")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  plan             SubscriptionPlan
  status           SubscriptionStatus @default(TRIAL)
  billingCycle     BillingCycle
  startsAt         DateTime           @db.Timestamptz
  currentPeriodEnd DateTime           @db.Timestamptz
  trialEndsAt      DateTime?          @db.Timestamptz
  cancelledAt      DateTime?          @db.Timestamptz
  createdAt        DateTime           @default(now()) @db.Timestamptz

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planRef  SubscriptionPlanRef @relation(fields: [plan], references: [code])
  invoices Invoice[]

  @@index([tenantId])
  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  subscriptionId String        @db.Uuid
  invoiceNumber  String        @unique
  amount         Decimal       @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String        @default("TRY")
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?     @db.Timestamptz
  pdfUrl         String?
  createdAt      DateTime      @default(now()) @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@map("invoices")
}

model SuperAdmin {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.Citext
  passwordHash String
  fullName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz

  @@map("super_admins")
}

// ─────────────────────────── RESTAURANT / TABLE ───────────────────────────

model Restaurant {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String       @db.Uuid
  name               String
  logoUrl            String?
  coverUrl           String?
  address            String?
  phone              String?
  timezone           String       @default("Europe/Istanbul")
  currency           String       @default("TRY")
  vatRate            Decimal      @default(10.0) @db.Decimal(5, 2)
  serviceFee         Decimal      @default(0) @db.Decimal(5, 2)
  defaultLang        LanguageCode @default(TR)
  socialLinks        Json         @default("{}")
  notificationSounds Json         @default("{}")
  openingHours       Json         @default("{}")
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now()) @db.Timestamptz
  updatedAt          DateTime     @updatedAt @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections       Section[]
  tables         Table[]
  users          User[]
  shifts         Shift[]
  categories     Category[]
  products       Product[]
  modifierGroups ModifierGroup[]
  tableSessions  TableSession[]
  orders         Order[]
  tableCalls     TableCall[]
  payments       Payment[]
  campaigns      Campaign[]
  coupons        Coupon[]
  events         Event[]

  @@index([tenantId])
  @@map("restaurants")
}

model Section {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  restaurantId String  @db.Uuid
  name         String
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables     Table[]

  @@index([restaurantId])
  @@map("sections")
}

model Table {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  restaurantId String      @db.Uuid
  sectionId    String?     @db.Uuid
  label        String
  capacity     Int         @default(4)
  qrToken      String      @unique
  status       TableStatus @default(EMPTY)
  positionX    Int?
  positionY    Int?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now()) @db.Timestamptz

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  section    Section?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  sessions   TableSession[]
  orders     Order[]
  calls      TableCall[]
  events     Event[]

  @@unique([restaurantId, label])
  @@index([restaurantId, status])
  @@map("tables")
}

// ─────────────────────────── USERS / SHIFTS ───────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  restaurantId String?   @db.Uuid
  email        String?   @db.Citext
  username     String    @db.Citext
  passwordHash String
  fullName     String
  role         UserRole
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  shifts            Shift[]
  ordersAsWaiter    Order[]         @relation("OrderWaiter")
  paymentsCollected Payment[]       @relation("PaymentCollector")
  acknowledgedCalls TableCall[]     @relation("CallAcknowledger")
  openedSessions    TableSession[]  @relation("SessionOpener")
  events            Event[]         @relation("EventActor")
  auditLogs         AuditLog[]
  offlineOutbox     OfflineOutbox[]

  @@unique([tenantId, username])
  @@index([tenantId, role])
  @@map("users")
}

model Shift {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  restaurantId String      @db.Uuid
  userId       String      @db.Uuid
  status       ShiftStatus @default(OPEN)
  startedAt    DateTime    @default(now()) @db.Timestamptz
  endedAt      DateTime?   @db.Timestamptz
  openingCash  Decimal?    @default(0) @db.Decimal(10, 2)
  closingCash  Decimal?    @db.Decimal(10, 2)
  notes        String?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  orders     Order[]
  payments   Payment[]

  @@index([userId, status])
  @@map("shifts")
}

// ─────────────────────────── MENU ───────────────────────────

model Category {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @db.Uuid
  restaurantId String      @db.Uuid
  parentId     String?     @db.Uuid
  name         Json // {"TR":"Çorbalar","EN":"Soups"}
  description  Json?
  imageUrl     String?
  station      StationType @default(KITCHEN)
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   Category[] @relation("CategoryTree")
  products   Product[]

  @@index([restaurantId, sortOrder])
  @@map("categories")
}

model Product {
  id           String                   @id @default(uuid()) @db.Uuid
  tenantId     String                   @db.Uuid
  restaurantId String                   @db.Uuid
  categoryId   String                   @db.Uuid
  sku          String?
  name         Json // {"TR":"...","EN":"..."}
  description  Json?
  ingredients  Json?
  basePrice    Decimal                  @db.Decimal(10, 2)
  costPrice    Decimal?                 @db.Decimal(10, 2)
  prepTimeMin  Int?
  station      StationType?
  tags         String[]                 @default([])
  allergens    String[]                 @default([])
  isAvailable  Boolean                  @default(true)
  isActive     Boolean                  @default(true)
  sortOrder    Int                      @default(0)
  // search_vector tsvector — trigger ile yönetilir, Prisma'da Unsupported
  searchVector Unsupported("tsvector")?
  createdAt    DateTime                 @default(now()) @db.Timestamptz
  updatedAt    DateTime                 @updatedAt @db.Timestamptz

  restaurant     Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category       Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images         ProductImage[]
  variants       ProductVariant[]
  modifierGroups ProductModifierGroup[]
  orderItems     OrderItem[]

  @@index([restaurantId, categoryId, isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @db.Uuid
  productId String  @db.Uuid
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @db.Uuid
  productId  String  @db.Uuid
  name       Json
  priceDelta Decimal @default(0) @db.Decimal(10, 2)
  isDefault  Boolean @default(false)
  sortOrder  Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ModifierGroup {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  restaurantId String  @db.Uuid
  name         Json
  minSelect    Int     @default(0)
  maxSelect    Int     @default(1)
  isRequired   Boolean @default(false)

  restaurant Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  modifiers  Modifier[]
  products   ProductModifierGroup[]

  @@map("modifier_groups")
}

model Modifier {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @db.Uuid
  groupId    String  @db.Uuid
  name       Json
  priceDelta Decimal @default(0) @db.Decimal(10, 2)
  isActive   Boolean @default(true)
  sortOrder  Int     @default(0)

  group              ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@index([groupId])
  @@map("modifiers")
}

model ProductModifierGroup {
  productId       String @db.Uuid
  modifierGroupId String @db.Uuid
  sortOrder       Int    @default(0)

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
  @@map("product_modifier_groups")
}

// ─────────────────────────── ORDER FLOW ───────────────────────────

model TableSession {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  restaurantId   String    @db.Uuid
  tableId        String    @db.Uuid
  openedByUserId String?   @db.Uuid
  guestCount     Int?
  openedAt       DateTime  @default(now()) @db.Timestamptz
  closedAt       DateTime? @db.Timestamptz
  totalAmount    Decimal   @default(0) @db.Decimal(10, 2)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table      @relation(fields: [tableId], references: [id])
  openedBy   User?      @relation("SessionOpener", fields: [openedByUserId], references: [id])
  orders     Order[]
  payments   Payment[]

  @@index([tableId, closedAt])
  @@map("table_sessions")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  restaurantId    String      @db.Uuid
  sessionId       String      @db.Uuid
  tableId         String      @db.Uuid
  waiterId        String      @db.Uuid
  shiftId         String?     @db.Uuid
  orderNumber     String
  status          OrderStatus @default(CONFIRMED)
  subtotal        Decimal     @default(0) @db.Decimal(10, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(10, 2)
  serviceFee      Decimal     @default(0) @db.Decimal(10, 2)
  vatTotal        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @default(0) @db.Decimal(10, 2)
  note            String?
  cancelledReason String?
  createdAt       DateTime    @default(now()) @db.Timestamptz
  confirmedAt     DateTime?   @db.Timestamptz
  readyAt         DateTime?   @db.Timestamptz
  servedAt        DateTime?   @db.Timestamptz
  cancelledAt     DateTime?   @db.Timestamptz

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  session    TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  table      Table        @relation(fields: [tableId], references: [id])
  waiter     User         @relation("OrderWaiter", fields: [waiterId], references: [id])
  shift      Shift?       @relation(fields: [shiftId], references: [id])
  items      OrderItem[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, status, createdAt])
  @@index([waiterId, createdAt])
  @@index([sessionId])
  @@map("orders")
}

model OrderItem {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @db.Uuid
  orderId             String          @db.Uuid
  productId           String          @db.Uuid
  variantId           String?         @db.Uuid
  productNameSnapshot String
  station             StationType
  quantity            Int
  unitPrice           Decimal         @db.Decimal(10, 2)
  modifiersTotal      Decimal         @default(0) @db.Decimal(10, 2)
  lineTotal           Decimal         @db.Decimal(10, 2)
  cookingPref         String?
  customerNote        String?
  status              OrderItemStatus @default(PENDING)
  preparingAt         DateTime?       @db.Timestamptz
  readyAt             DateTime?       @db.Timestamptz
  servedAt            DateTime?       @db.Timestamptz
  cancelledAt         DateTime?       @db.Timestamptz
  createdAt           DateTime        @default(now()) @db.Timestamptz

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id])
  variant   ProductVariant?     @relation(fields: [variantId], references: [id])
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([station, status, createdAt])
  @@map("order_items")
}

model OrderItemModifier {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @db.Uuid
  orderItemId  String  @db.Uuid
  modifierId   String  @db.Uuid
  nameSnapshot String
  priceDelta   Decimal @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier  Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// ─────────────────────────── CALLS / PAYMENTS / CAMPAIGNS ───────────────────────────

model TableCall {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @db.Uuid
  restaurantId   String         @db.Uuid
  tableId        String         @db.Uuid
  type           CallType
  status         CallStatus     @default(PENDING)
  paymentHint    PaymentMethod?
  createdAt      DateTime       @default(now()) @db.Timestamptz
  acknowledgedAt DateTime?      @db.Timestamptz
  acknowledgedBy String?        @db.Uuid
  resolvedAt     DateTime?      @db.Timestamptz

  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table              Table      @relation(fields: [tableId], references: [id])
  acknowledgedByUser User?      @relation("CallAcknowledger", fields: [acknowledgedBy], references: [id])

  @@index([restaurantId, status, createdAt])
  @@map("table_calls")
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  restaurantId String        @db.Uuid
  sessionId    String        @db.Uuid
  collectedBy  String        @db.Uuid
  shiftId      String?       @db.Uuid
  method       PaymentMethod
  amount       Decimal       @db.Decimal(10, 2)
  tip          Decimal       @default(0) @db.Decimal(10, 2)
  status       PaymentStatus @default(PAID)
  note         String?
  createdAt    DateTime      @default(now()) @db.Timestamptz

  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  session    TableSession @relation(fields: [sessionId], references: [id])
  collector  User         @relation("PaymentCollector", fields: [collectedBy], references: [id])
  shift      Shift?       @relation(fields: [shiftId], references: [id])

  @@index([sessionId])
  @@index([shiftId, createdAt])
  @@map("payments")
}

model Campaign {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @db.Uuid
  restaurantId  String         @db.Uuid
  name          String
  description   String?
  discountType  DiscountType
  discountValue Decimal        @db.Decimal(10, 2)
  appliesTo     DiscountTarget
  targetIds     String[]       @default([]) @db.Uuid
  startsAt      DateTime       @db.Timestamptz
  endsAt        DateTime       @db.Timestamptz
  hourFrom      String? // "12:00"
  hourTo        String? // "15:00"
  weekdays      Int[]          @default([1, 2, 3, 4, 5, 6, 7])
  isActive      Boolean        @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, isActive, startsAt, endsAt])
  @@map("campaigns")
}

model Coupon {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @db.Uuid
  restaurantId  String       @db.Uuid
  code          String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int          @default(0)
  validFrom     DateTime     @db.Timestamptz
  validTo       DateTime     @db.Timestamptz
  isActive      Boolean      @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, code])
  @@map("coupons")
}

// ─────────────────────────── EVENTS / AUDIT / OFFLINE ───────────────────────────

model Event {
  id           BigInt   @id @default(autoincrement())
  tenantId     String   @db.Uuid
  restaurantId String   @db.Uuid
  type         String
  actorUserId  String?  @db.Uuid
  tableId      String?  @db.Uuid
  payload      Json     @default("{}")
  createdAt    DateTime @default(now()) @db.Timestamptz

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actor      User?      @relation("EventActor", fields: [actorUserId], references: [id])
  table      Table?     @relation(fields: [tableId], references: [id])

  @@index([restaurantId, createdAt])
  @@index([type, createdAt])
  @@map("events")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  tenantId  String   @db.Uuid
  userId    String?  @db.Uuid
  entity    String
  entityId  String   @db.Uuid
  action    String
  before    Json?
  after     Json?
  ip        String?  @db.Inet
  createdAt DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model OfflineOutbox {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  userId        String    @db.Uuid
  clientEventId String
  type          String
  payload       Json
  appliedAt     DateTime? @db.Timestamptz
  error         String?
  createdAt     DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, clientEventId])
  @@map("offline_outbox")
}
