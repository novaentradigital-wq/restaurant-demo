{
  "name": "qr-menu-saas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @qrmenu/db generate",
    "db:migrate": "pnpm --filter @qrmenu/db migrate",
    "db:push": "pnpm --filter @qrmenu/db push",
    "db:seed": "pnpm --filter @qrmenu/db seed",
    "db:studio": "pnpm --filter @qrmenu/db studio",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}
