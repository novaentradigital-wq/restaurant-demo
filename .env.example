# ───────── Database ─────────
DATABASE_URL="postgresql://qrmenu:qrmenu@localhost:5432/qrmenu?schema=public"
DIRECT_URL="postgresql://qrmenu:qrmenu@localhost:5432/qrmenu?schema=public"

# ───────── Redis ─────────
REDIS_URL="redis://localhost:6379"

# ───────── Auth ─────────
JWT_ACCESS_SECRET="change-me-access-min-32-chars-xxxxxxxxxx"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-xxxxxxxxx"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ───────── Storage (MinIO/S3) ─────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="qrmenu"
S3_SECRET_KEY="qrmenuqrmenu"
S3_BUCKET_PUBLIC="qrmenu-public"

# ───────── App URLs ─────────
APP_BASE_DOMAIN="sistemadi.com"
API_PORT=4000
WEB_URL_CUSTOMER="http://localhost:3000"
WEB_URL_WAITER="http://localhost:3001"
WEB_URL_KITCHEN="http://localhost:3002"
WEB_URL_ADMIN="http://localhost:3003"
WEB_URL_SUPER_ADMIN="http://localhost:3004"

# ───────── Misc ─────────
NODE_ENV="development"
LOG_LEVEL="debug"
